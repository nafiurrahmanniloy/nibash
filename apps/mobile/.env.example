# ─────────────────────────────────────────────────────────────────────────────
# Travela mobile (Expo) — environment template.
# Copy to `.env` and fill in. Never commit the real file.
# Only EXPO_PUBLIC_* vars are embedded in the client bundle (Expo convention);
# the service-role key NEVER ships to the device — server-only work stays on web.
# Validated at boot by src/lib/env.ts (fail-fast, zod).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Postgres / Auth / Storage / Realtime) — RLS-guarded anon key ────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
