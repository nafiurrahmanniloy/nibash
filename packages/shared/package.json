{
  "name": "@nibash/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cross-platform contract layer (types, zod schemas, design tokens, supabase types, api helpers) shared by @nibash web and mobile.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./tokens/tailwind-preset": {
      "types": "./src/tokens/tailwind-preset.ts",
      "import": "./src/tokens/tailwind-preset.ts",
      "default": "./src/tokens/tailwind-preset.ts"
    },
    "./tokens/css-variables.css": "./src/tokens/css-variables.css",
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "import": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    },
    "./supabase": {
      "types": "./src/supabase/index.ts",
      "import": "./src/supabase/index.ts",
      "default": "./src/supabase/index.ts"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "import": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
