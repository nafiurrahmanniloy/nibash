# ─────────────────────────────────────────────────────────────────────────────
# Travela Stay Platform — environment template (BUILD-PLAN §8)
# Copy to `.env` (or apps/web/.env.local) and fill in. Never commit the real file.
# All vars are validated at boot by apps/web/src/lib/env.ts (fail-fast, zod).
# NEXT_PUBLIC_* are exposed to the browser; everything else is server-only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Postgres / Auth / Storage / Realtime) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co   # project API URL (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key              # anon key, RLS-guarded (public)
SUPABASE_SERVICE_ROLE=your-service-role-secret                  # bypasses RLS — server only, never ship to client

# ── Site / origins ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000                     # canonical origin; SSLCommerz callbacks + emails build off this

# ── SSLCommerz (payments: cards + bKash + Nagad + bank) ──────────────────────
SSLCOMMERZ_STORE_ID=your-store-id                              # client-provided store id
SSLCOMMERZ_STORE_PASSWORD=your-store-password                  # client-provided store password (secret)
SSLCOMMERZ_IS_SANDBOX=true                                     # true = sandbox gateway, false = production

# ── Google Maps (static maps on cards, JS map on detail) ─────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-api-key             # restrict by referrer/IP in GCP (public)

# ── Email (Resend, or SMTP from client) ──────────────────────────────────────
RESEND_API_KEY=your-resend-api-key                            # transactional email (booking events)
EMAIL_FROM="Travela <bookings@your-domain.com>"               # verified sender address

# ── Push notifications (Expo Push / FCM) ─────────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id                      # Firebase project id
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com  # service-account email
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-key-with-escaped-newlines\n-----END PRIVATE KEY-----\n"  # service-account private key (escaped \n)
