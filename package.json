{
  "name": "nibash-stay-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Short-term stay booking platform (Nibash-style) — Turborepo monorepo: web (Next.js), mobile (Expo), shared package.",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "eslint": "^9.13.0"
  }
}
